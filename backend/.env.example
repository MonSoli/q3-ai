# Qwen3 Web UI Backend Configuration
# Copy this file to .env and modify as needed

# Secret key for JWT tokens (auto-generated if not set)
# SECRET_KEY=your-secret-key-here

# Database
# DB_PATH=./qwen3_data.db

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Admin credentials (used on first startup only)
ADMIN_EMAIL=admin@qwen3.local
ADMIN_PASSWORD=ChangeMe!2024

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password policy
MIN_PASSWORD_LENGTH=8

# Rate limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_DEFAULT=60/minute

# Max upload size in bytes (default 50MB)
MAX_UPLOAD_SIZE=52428800
